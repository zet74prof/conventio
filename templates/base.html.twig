<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Conventio{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">Conventio</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_home') }}">{% trans %}Accueil{% endtrans %}</a>
                </li>
                {# Add more public links here if needed #}
            </ul>
            <ul class="navbar-nav ms-auto">
                {% if app.user %}
                    {# PROFESSOR SECTION - Only visible to Professors #}
                    {% if is_granted('ROLE_PROFESSOR') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="profDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-mortarboard-fill"></i> {% trans %}Enseignant{% endtrans %}
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="profDropdown">
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_professor_students') }}">
                                        <i class="bi bi-people-fill me-2 text-primary"></i>
                                        {% trans %}Mes Étudiants{% endtrans %}
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_professor_contract_index') }}">
                                        <i class="bi bi-card-checklist me-2 text-primary"></i>
                                        {% trans %}Conventions à valider{% endtrans %}
                                    </a>
                                </li>
                            </ul>
                        </li>
                    {% endif %}

                    {# ADMIN SECTION - Only visible to Admins #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-shield-lock-fill"></i> {% trans %}Administration{% endtrans %}
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="adminDropdown">

                                {# 1. Levels / Formations #}
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_level_index') }}">
                                        <i class="bi bi-mortarboard me-2 text-primary"></i>
                                        {% trans %}Formations{% endtrans %}
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                {# 3. Parameters #}
                                <li>
                                    {# Ensure the route 'app_admin_parameters' exists, otherwise this will cause an error #}
                                    <a class="dropdown-item" href="{{ path('app_admin_parameters') }}">
                                        <i class="bi bi-sliders me-2 text-secondary"></i>
                                        {% trans %}Paramètres{% endtrans %}
                                    </a>
                                </li>
                            </ul>
                        </li>
                    {% endif %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> {{ app.user.userIdentifier }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="{{ path('app_profile_edit') }}">{% trans %}Profil{% endtrans %}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_profile_changepassword') }}">{% trans %}Modifier mon mot de passe{% endtrans %}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_logout') }}">{% trans %}Se déconnecter{% endtrans %}</a></li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">{% trans %}Connexion{% endtrans %}</a>
                    </li>
                    <li class="nav-item">
                        {# Note: Ensure you create a registration route named 'app_register' #}
                        <a class="nav-link btn btn-outline-light ms-2" href="{{ path('app_register') }}">{% trans %}Inscription{% endtrans %}</a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<div class="container">
    {% block body %}{% endblock %}
</div>
</body>
</html>
