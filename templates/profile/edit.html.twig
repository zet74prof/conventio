{% extends 'base.html.twig' %}

{% block title %}{% trans %}Mon Profil{% endtrans %}{% endblock %}

{% block body %}
    <div class="container mt-5">
        {# --- DÉBUT BLOC FLASH MESSAGES --- #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                {# On transforme le label 'error' en 'danger' pour correspondre aux classes Bootstrap #}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
        {# --- FIN BLOC FLASH MESSAGES --- #}
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white">
                        <h3 class="card-title mb-0">
                            <i class="bi bi-person-circle me-2"></i>
                            {% trans %}Mon Profil{% endtrans %}
                            {% if user_type == 'Student' %}
                                <small class="text-white-50">({% trans %}Étudiant{% endtrans %})</small>
                            {% elseif user_type == 'Professor' %}
                                <small class="text-white-50">({% trans %}Professeur{% endtrans %})</small>
                            {% endif %}
                        </h3>
                    </div>
                    <div class="card-body">
                        {# Display User Info (Read Only) #}
                        <div class="mb-4 p-3 bg-light rounded">
                            <div class="row">
                                <div class="col-sm-4 fw-bold">{% trans %}Nom complet{% endtrans %}</div>
                                <div class="col-sm-8">{{ app.user.fullName }}</div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-sm-4 fw-bold">{% trans %}Email de connexion{% endtrans %}</div>
                                <div class="col-sm-8">{{ app.user.email }}</div>
                            </div>
                        </div>

                        <hr>

                        {# Editable Form #}
                        {{ form_start(form) }}
                        <h5 class="mb-3 text-secondary">{% trans %}Informations Personnelles{% endtrans %}</h5>
                        {% if form.personalEmail is defined %}
                            <div class="form-floating mb-3">
                                {{ form_widget(form.personalEmail, {'attr': {'class': 'form-control'}}) }}
                                {{ form_label(form.personalEmail) }}
                                {{ form_errors(form.personalEmail) }}
                            </div>
                        {% endif %}

                        <div class="form-floating mb-4">
                            {{ form_widget(form.mobilePhone, {'attr': {'class': 'form-control'}}) }}
                            {{ form_label(form.mobilePhone) }}
                            {{ form_errors(form.mobilePhone) }}
                        </div>

                        <hr>
                        <h5 class="mb-3 text-secondary">{% trans %}Affectations Scolaires{% endtrans %}</h5>

                        {% if form.level is defined %}
                            <div class="form-floating mb-3">
                                {{ form_widget(form.level, {'attr': {'class': 'form-select'}}) }}
                                {{ form_label(form.level) }}
                                {{ form_errors(form.level) }}
                            </div>
                        {% elseif form.levels is defined %}
                            <div class="mb-3">
                                {{ form_label(form.levels, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.levels, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.levels) }}
                                {% if form.levels.vars.help is defined and form.levels.vars.help %}
                                    <div class="form-text">{{ form.levels.vars.help|trans }}</div>
                                {% endif %}
                            </div>
                        {% endif %}

                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> {% trans %}Enregistrer les modifications{% endtrans %}
                            </button>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
