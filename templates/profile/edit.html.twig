{% extends 'base.html.twig' %}

{% block title %}{% trans %}Mon Profil{% endtrans %}{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white">
                        <h3 class="card-title mb-0">
                            <i class="bi bi-person-circle me-2"></i>
                            {% trans %}Mon Profil{% endtrans %}
                            {% if user_type == 'Student' %}
                                <small class="text-white-50">({% trans %}Étudiant{% endtrans %})</small>
                            {% elseif user_type == 'Professor' %}
                                <small class="text-white-50">({% trans %}Professeur{% endtrans %})</small>
                            {% endif %}
                        </h3>
                    </div>
                    <div class="card-body">
                        {# Display User Info (Read Only) #}
                        <div class="mb-4 p-3 bg-light rounded">
                            <div class="row">
                                <div class="col-sm-4 fw-bold">{% trans %}Nom complet{% endtrans %}</div>
                                <div class="col-sm-8">{{ app.user.fullName }}</div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-sm-4 fw-bold">{% trans %}Email de connexion{% endtrans %}</div>
                                <div class="col-sm-8">{{ app.user.email }}</div>
                            </div>
                        </div>

                        <hr>

                        {# Editable Form #}
                        {{ form_start(form) }}

                        {% if user_type == 'Student' %}
                            <h5 class="mb-3 text-secondary">{% trans %}Informations Scolaires{% endtrans %}</h5>
                            <div class="form-floating mb-3">
                                {{ form_widget(form.personalEmail) }}
                                {{ form_label(form.personalEmail) }}
                                {{ form_errors(form.personalEmail) }}
                            </div>
                            <div class="form-floating mb-3">
                                {{ form_widget(form.level) }}
                                {{ form_label(form.level) }}
                                {{ form_errors(form.level) }}
                            </div>
                        {% elseif user_type == 'Professor' %}
                            <h5 class="mb-3 text-secondary">{% trans %}Accès Pédagogiques{% endtrans %}</h5>
                            <div class="mb-3">
                                {{ form_label(form.levels) }}
                                {{ form_widget(form.levels) }}
                                <div class="form-text">{{ form_help(form.levels) }}</div>
                                {{ form_errors(form.levels) }}
                            </div>
                        {% endif %}

                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> {% trans %}Enregistrer les modifications{% endtrans %}
                            </button>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
