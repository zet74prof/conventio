{% extends 'base.html.twig' %}

{% block title %}Nouvelle Formation{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h3 class="card-title mb-0">Nouvelle Formation</h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(form) }}
                        <div class="form-floating mb-3">
                            {{ form_widget(form.levelCode) }}
                            {{ form_label(form.levelCode) }}
                            {{ form_errors(form.levelCode) }}
                        </div>

                        <div class="form-floating mb-3">
                            {{ form_widget(form.levelName) }}
                            {{ form_label(form.levelName) }}
                            {{ form_errors(form.levelName) }}
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('app_level_index') }}" class="btn btn-outline-secondary">Retour à la liste</a>
                            <button class="btn btn-primary">Enregistrer</button>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
