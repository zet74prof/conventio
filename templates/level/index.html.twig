{% extends 'base.html.twig' %}

{% block title %}Gestion des Formations{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Gestion des Formations</h1>
            <a href="{{ path('app_level_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Créer une nouvelle formation
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                    <tr>
                        <th>Id</th>
                        <th>Code</th>
                        <th>Libellé</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for level in levels %}
                        <tr>
                            <td>{{ level.id }}</td>
                            <td><span class="badge bg-secondary">{{ level.levelCode }}</span></td>
                            <td>{{ level.levelName }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_level_show', {'id': level.id}) }}" class="btn btn-sm btn-info text-white me-1">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_level_edit', {'id': level.id}) }}" class="btn btn-sm btn-warning text-white">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center text-muted">Aucune formation enregistrée.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
