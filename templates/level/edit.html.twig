{% extends 'base.html.twig' %}

{% block title %}Modifier la Formation{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-warning text-white">
                        <h3 class="card-title mb-0">Modifier la Formation</h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(form) }}
                        <div class="form-floating mb-3">
                            {{ form_widget(form.levelCode) }}
                            {{ form_label(form.levelCode) }}
                            {{ form_errors(form.levelCode) }}
                        </div>

                        <div class="form-floating mb-3">
                            {{ form_widget(form.levelName) }}
                            {{ form_label(form.levelName) }}
                            {{ form_errors(form.levelName) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.referentProfessors) }}
                            {{ form_widget(form.referentProfessors) }}
                            {{ form_errors(form.referentProfessors) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Dates de stage</label>
                            <div id="internship-dates-container" {{ stimulus_controller('form-collection', {
                                index: form.internshipDates|length > 0 ? form.internshipDates|last.vars.name + 1 : 0,
                                prototype: form_row(form.internshipDates.vars.prototype)
                            }) }}>
                                <div data-form-collection-target="container">
                                    {% for dateForm in form.internshipDates %}
                                        <div class="card mb-2 bg-light border-0 form-collection-item">
                                            <div class="card-body p-2 d-flex gap-2 align-items-end">
                                                <div class="flex-grow-1">
                                                    {{ form_row(dateForm.startDate) }}
                                                </div>
                                                <div class="flex-grow-1">
                                                    {{ form_row(dateForm.endDate) }}
                                                </div>
                                                <button type="button" class="btn btn-outline-danger mb-3" data-action="form-collection#remove">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>

                                <button type="button" class="btn btn-outline-primary btn-sm mt-2" data-action="form-collection#add">
                                    <i class="bi bi-plus-circle me-1"></i> Ajouter une période
                                </button>

                                {# Hidden unrendered part of the collection to avoid form_end rendering it #}
                                {% do form.internshipDates.setRendered() %}
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('app_level_index') }}" class="btn btn-outline-secondary">Retour</a>
                            <button class="btn btn-warning text-white">Mettre à jour</button>
                        </div>
                        {{ form_end(form) }}
                    </div>
                    <div class="card-footer bg-light">
                        {{ include('level/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
