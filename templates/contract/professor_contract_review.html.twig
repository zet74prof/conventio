{% extends 'base.html.twig' %}

{% block title %}{% trans %}Révision Convention{% endtrans %}{% endblock %}

{% block body %}
    <div class="container mt-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>{% trans %}Validation Pédagogique{% endtrans %} : {{ contract.student.fullName }}</h2>
            <a href="{{ path('app_professor_contract_index') }}" class="btn btn-outline-secondary">{% trans %}Retour{% endtrans %}</a>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header bg-light"><strong>{% trans %}Missions et Activités{% endtrans %}</strong></div>
                    <div class="card-body">
                        <p class="lead">{{ contract.plannedActivities|nl2br }}</p>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-light"><strong>{% trans %}Détails du stage{% endtrans %}</strong></div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item"><strong>{% trans %}Entreprise{% endtrans %} :</strong> {{ contract.organisation.name }}</li>
                            <li class="list-group-item"><strong>{% trans %}Tuteur{% endtrans %} :</strong> {{ contract.tutor.fullName }} ({{ contract.tutor.email }})</li>
                            <li class="list-group-item"><strong>{% trans %}Lieu{% endtrans %} :</strong>
                                {% if contract.addressInternship %}
                                    {{ contract.addressInternship }}, {{ contract.cityInternship }}
                                {% else %}
                                    <em>{% trans %}Siège social{% endtrans %}</em>
                                {% endif %}
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow sticky-top" style="top: 20px;">
                    <div class="card-body">
                        <h5 class="card-title mb-3">{% trans %}Décision{% endtrans %}</h5>
                        <form method="post">
                            <div class="d-grid gap-2">
                                <button type="submit" name="approve" class="btn btn-success btn-lg">
                                    <i class="bi bi-check-circle-fill me-2"></i>{% trans %}Valider le stage{% endtrans %}
                                </button>
                                <button type="submit" name="reject" class="btn btn-outline-danger">
                                    <i class="bi bi-x-circle me-2"></i>{% trans %}Refuser / Demander corrections{% endtrans %}
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
