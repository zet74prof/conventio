{% extends 'base.html.twig' %}

{% block title %}Mes Étudiants{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-people-fill me-2"></i>Mes Étudiants par Formation</h1>
        <a href="{{ path('app_professor_contract_index') }}" class="btn btn-outline-primary">
            <i class="bi bi-card-checklist me-1"></i>Conventions à valider
        </a>
    </div>

    {% if levels is empty %}
        <div class="alert alert-info">
            Vous n'êtes affecté à aucune formation pour le moment.
        </div>
    {% else %}
        <div class="accordion" id="accordionLevels">
            {% for level in levels %}
                <div class="accordion-item shadow-sm mb-3">
                    <h2 class="accordion-header" id="headingLevel{{ level.id }}">
                        <button class="accordion-button {% if not loop.first %}collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#collapseLevel{{ level.id }}" aria-expanded="{{ loop.first ? 'true' : 'false' }}" aria-controls="collapseLevel{{ level.id }}">
                            <div class="d-flex justify-content-between w-100 me-3">
                                <span><strong>{{ level.levelCode }}</strong> - {{ level.levelName }}</span>
                                <span class="badge bg-primary rounded-pill">{{ level.students|length }} étudiant(s)</span>
                            </div>
                        </button>
                    </h2>
                    <div id="collapseLevel{{ level.id }}" class="accordion-collapse collapse {% if loop.first %}show{% endif %}" aria-labelledby="headingLevel{{ level.id }}" data-bs-parent="#accordionLevels">
                        <div class="accordion-body p-0">
                            {% if level.students is empty %}
                                <div class="p-3 text-muted italic">Aucun étudiant dans cette formation.</div>
                            {% else %}
                                <div class="list-group list-group-flush">
                                    {% for student in level.students %}
                                        <div class="list-group-item">
                                            <div class="d-flex justify-content-between align-items-center py-2">
                                                <div>
                                                    <h5 class="mb-1">{{ student.lastname|upper }} {{ student.firstname }}</h5>
                                                    <small class="text-muted"><i class="bi bi-envelope me-1"></i>{{ student.email }}</small>
                                                </div>
                                                <div>
                                                    <span class="badge bg-secondary rounded-pill">{{ student.contracts|length }} convention(s)</span>
                                                </div>
                                            </div>

                                            {% if student.contracts is not empty %}
                                                <div class="mt-2 ms-3 border-start ps-3">
                                                    <table class="table table-sm table-hover mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th>Session / Entreprise</th>
                                                                <th>Statut</th>
                                                                <th class="text-end">Actions</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            {% for contract in student.contracts %}
                                                                <tr>
                                                                    <td>
                                                                        {{ contract.internshipDate.startDate|date('d/m/Y') }} - {{ contract.internshipDate.endDate|date('d/m/Y') }}
                                                                        {% if contract.organisation %}
                                                                            <br><small class="text-muted">{{ contract.organisation.name }}</small>
                                                                        {% endif %}
                                                                    </td>
                                                                    <td>
                                                                        <span class="badge bg-{{ statusColors[contract.status]|default('secondary') }}">
                                                                            {{ statusLabels[contract.status]|default('Inconnu') }}
                                                                        </span>
                                                                    </td>
                                                                    <td class="text-end">
                                                                        {% if contract.status == 2 %} {# STATUS_APPROVAL_REQUESTED #}
                                                                            <a href="{{ path('app_professor_contract_review', {id: contract.id}) }}" class="btn btn-sm btn-warning">
                                                                                <i class="bi bi-eye"></i> Valider
                                                                            </a>
                                                                        {% endif %}
                                                                    </td>
                                                                </tr>
                                                            {% endfor %}
                                                        </tbody>
                                                    </table>
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
