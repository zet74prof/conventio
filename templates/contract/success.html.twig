{% extends 'base.html.twig' %}

{% block title %}{% trans %}Confirmation{% endtrans %}{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="card shadow-sm text-center py-5">
                    <div class="card-body">
                        <div class="mb-4 text-success">
                            <i class="bi bi-check-circle-fill" style="font-size: 4rem;"></i>
                        </div>

                        <h1 class="h3 card-title mb-3">{% trans %}Merci !{% endtrans %}</h1>

                        <p class="lead text-muted mb-4">
                            {% trans %}Les informations de la convention ont été enregistrées avec succès.{% endtrans %}
                        </p>

                        <p class="card-text mb-4">
                            {% trans %}Le service administratif va maintenant valider ces éléments.{% endtrans %}<br>
                            {% trans %}Vous recevrez prochainement un email vous invitant à signer la convention.{% endtrans %}
                        </p>

                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                            <a href="{{ path('app_home') }}" class="btn btn-outline-primary">
                                <i class="bi bi-house me-2"></i>{% trans %}Retour à l'accueil{% endtrans %}
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
