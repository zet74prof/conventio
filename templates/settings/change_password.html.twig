{% extends 'base.html.twig' %}

{% block title %}{% trans %}Modifier mon mot de passe{% endtrans %}{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white text-center py-3">
                        <h3 class="card-title mb-0">{% trans %}Modifier mon mot de passe{% endtrans %}</h3>
                    </div>
                    <div class="card-body p-4">
                        {{ form_start(form) }}

                        {# 1. Current Password #}
                        <div class="form-floating mb-3">
                            {{ form_widget(form.currentPassword, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Mot de passe actuel'
                                }
                            }) }}
                            {{ form_label(form.currentPassword) }}
                            {{ form_errors(form.currentPassword) }}
                        </div>

                        <hr class="my-4">

                        {# 2. New Password (First field) #}
                        <div class="form-floating mb-3">
                            {{ form_widget(form.plainPassword.first, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Nouveau mot de passe'
                                }
                            }) }}
                            {{ form_label(form.plainPassword.first) }}
                            {{ form_errors(form.plainPassword.first) }}
                        </div>

                        {# 3. Repeat Password (Second field) #}
                        <div class="form-floating mb-4">
                            {{ form_widget(form.plainPassword.second, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Répéter le mot de passe'
                                }
                            }) }}
                            {{ form_label(form.plainPassword.second) }}
                            {{ form_errors(form.plainPassword.second) }}
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button class="btn btn-primary btn-lg">{% trans %}Enregistrer{% endtrans %}</button>
                            <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">{% trans %}Annuler{% endtrans %}</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
