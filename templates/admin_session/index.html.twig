{% extends 'base.html.twig' %}

{% block title %}Gestion des Sessions{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Gestion des Sessions</h1>
            <a href="{{ path('app_session_new') }}" class="btn btn-primary">
                <i class="bi bi-calendar-plus"></i> {% trans %}Nouvelle Session{% endtrans %}
            </a>
        </div>

        {% if groupedSessions is empty %}
            <div class="alert alert-info">{% trans %}Aucune session enregistrée.{% endtrans %}</div>
        {% else %}

            {# Loop through Levels #}
            {% for levelName, levelData in groupedSessions %}
                <div class="card shadow-sm mb-5">
                    <div class="card-header bg-dark text-white">
                        <h3 class="card-title mb-0 h5">
                            <i class="bi bi-mortarboard-fill me-2"></i> {{ levelName }}
                        </h3>
                    </div>
                    <div class="card-body">

                        {# Loop through Years #}
                        {% for year, sessions in levelData.years %}
                            <div class="mb-4">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="bi bi-calendar3"></i> Année {{ year }}
                                </h5>

                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                        <tr>
                                            <th style="width: 20%;">#</th>
                                            <th style="width: 60%;">Dates (Début - Fin)</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {# Loop through Sessions #}
                                        {% for session in sessions %}
                                            <tr class="{{ not session.active ? 'table-secondary text-muted' : '' }}">
                                                <td class="fw-bold">
                                                    {{ session.computedName }}

                                                    {# Status Badge #}
                                                    {% if session.active %}
                                                        <span class="badge bg-success ms-2">{% trans %}Active{% endtrans %}</span>
                                                    {% else %}
                                                        <span class="badge bg-secondary ms-2">{% trans %}Inative{% endtrans %}</span>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    <ul class="list-unstyled mb-0 small">
                                                        {% for date in session.sessionDates %}
                                                            <li class="mb-1">
                                                                <i class="bi bi-calendar-event text-secondary"></i>
                                                                {{ date.startDate|date('d/m/Y') }}
                                                                <i class="bi bi-arrow-right-short"></i>
                                                                {{ date.endDate|date('d/m/Y') }}
                                                            </li>
                                                        {% endfor %}
                                                    </ul>
                                                </td>
                                                <td class="text-end">
                                                    <a href="{{ path('app_session_edit', {'id': session.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form method="post" action="{{ path('app_session_delete', {'id': session.id}) }}" class="d-inline" onsubmit="return confirm('{% trans %}Supprimer cette session ?{% endtrans %}');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ session.id) }}">
                                                        <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}

        {% endif %}
    </div>
{% endblock %}
