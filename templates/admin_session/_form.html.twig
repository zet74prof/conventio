{{ form_start(form) }}

    {# Card 1: General Information #}
<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="card-title mb-0">{% trans %}Informations Générales{% endtrans %}</h5>
    </div>
    <div class="card-body">
        <div class="row">
            {# Level Selection #}
            <div class="col-md-8">
                <div class="form-floating mb-3">
                    {{ form_widget(form.level) }}
                    {{ form_label(form.level) }}
                    {{ form_errors(form.level) }}
                </div>
            </div>

            {# Active Switch #}
            <div class="col-md-4">
                {# 1. Outer Box: Handles the border, gray background, and spacing #}
                <div class="p-3 border rounded bg-light w-100 h-100 d-flex align-items-center">

                    {# 2. Inner Box: Handles the specific Bootstrap Switch mechanics #}
                    <div class="form-check form-switch">
                        {{ form_widget(form.active) }}
                        {{ form_label(form.active, null, {'label_attr': {'class': 'form-check-label fw-bold'}}) }}

                        {% if form.active.vars.help %}
                            <div class="form-text mt-1 small text-muted">
                                {{ form_help(form.active) }}
                            </div>
                        {% endif %}

                        {{ form_errors(form.active) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Card 2: Dates / Periods #}
<div class="card shadow-sm mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">{% trans %}Périodes / Dates{% endtrans %}</h5>
    </div>
    <div class="card-body">

        {# Global Error for the Collection (e.g. "Min 1 date") #}
        <div class="text-danger mb-3">
            {{ form_errors(form.sessionDates) }}
        </div>

        {# Stimulus Controller Wrapper #}
        <div data-controller="form-collection"
             data-form-collection-index-value="{{ form.sessionDates|length }}"
             data-form-collection-prototype-value="{{ form_widget(form.sessionDates.vars.prototype)|e('html_attr') }}">

            {# The container where new items will be appended #}
            <div id="session-dates-wrapper" data-form-collection-target="collectionContainer">

                {% for dateField in form.sessionDates %}
                    <div class="row mb-3 session-date-item border-bottom pb-3 align-items-center">
                        <div class="col-md-10">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-calendar-range"></i></span>
                                        {{ form_widget(dateField.startDate, {'attr': {'placeholder': 'Début'}}) }}
                                    </div>
                                    {{ form_errors(dateField.startDate) }}
                                </div>
                                <div class="col-md-6">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-calendar-check"></i></span>
                                        {{ form_widget(dateField.endDate, {'attr': {'placeholder': 'Fin'}}) }}
                                    </div>
                                    {{ form_errors(dateField.endDate) }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 text-end">
                            <button type="button" class="btn btn-outline-danger btn-sm" data-action="click->form-collection#removeCollectionElement" title="{% trans %}Supprimer{% endtrans %}">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="mt-3">
                <button type="button" class="btn btn-success btn-sm" data-action="click->form-collection#addCollectionElement">
                    <i class="bi bi-plus-circle me-1"></i> {% trans %}Ajouter une période{% endtrans %}
                </button>
            </div>
        </div>

    </div>
</div>

<div class="d-flex justify-content-end gap-2">
    <a href="{{ path('app_session_index') }}" class="btn btn-outline-secondary">{% trans %}Annuler{% endtrans %}</a>
    <button class="btn btn-primary px-4">{{ button_label|default('Enregistrer')|trans }}</button>
</div>

{{ form_end(form) }}
