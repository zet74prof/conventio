{% extends 'base.html.twig' %}

{% block title %}{% trans %}Réinitialiser votre mot de passe{% endtrans %}{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white text-center py-3">
                        <h3 class="card-title mb-0">{% trans %}Mot de passe oublié{% endtrans %}</h3>
                    </div>
                    <div class="card-body p-4">
                        {% for flash_error in app.flashes('reset_password_error') %}
                            <div class="alert alert-danger" role="alert">{{ flash_error|trans({}, 'ResetPasswordBundle') }}</div>
                        {% endfor %}

                        <p class="text-muted small mb-4">
                            {% trans %}Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.{% endtrans %}
                        </p>

                        {{ form_start(requestForm) }}
                        <div class="form-floating mb-3">
                            {{ form_widget(requestForm.email) }}
                            {{ form_label(requestForm.email) }}
                            {{ form_errors(requestForm.email) }}
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-lg">{% trans %}Envoyer le lien{% endtrans %}</button>
                            <a href="{{ path('app_login') }}" class="btn btn-link text-decoration-none">{% trans %}Retour à la connexion{% endtrans %}</a>
                        </div>
                        {{ form_end(requestForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
