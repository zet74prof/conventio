<h1>{% trans from 'ResetPasswordBundle' %}Hi!{% endtrans %}</h1>

<p>
    {% trans from 'ResetPasswordBundle' %}To reset your password, please visit the following link{% endtrans %}
</p>

<a href="{{ url('app_reset_password', {token: resetToken.token}) }}">{{ url('app_reset_password', {token: resetToken.token}) }}</a>

<p>
    {% trans from 'ResetPasswordBundle' %}This link will expire in{% endtrans %} {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
</p>

<p>
    {% trans from 'ResetPasswordBundle' %}Cheers!{% endtrans %}
</p>
