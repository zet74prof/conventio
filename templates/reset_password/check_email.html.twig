{% extends 'base.html.twig' %}

{% block title %}{% trans %}Email envoyé{% endtrans %}{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="alert alert-success shadow-sm" role="alert">
                    <h4 class="alert-heading">{% trans %}Email de réinitialisation envoyé{% endtrans %}</h4>
                    <p>
                        {% trans %}
                            Si un compte existe avec cette adresse email, un email vient d'être envoyé contenant un lien pour réinitialiser votre mot de passe.
                            Ce lien expirera dans
                        {% endtrans %} {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                    </p>
                    <hr>
                    <p class="mb-0 small">
                        {% trans %}
                            Si vous ne recevez pas d'email, veuillez vérifier votre dossier spam ou
                        {% endtrans %}
                        <a href="{{ path('app_forgot_password_request') }}" class="alert-link">{% trans %}réessayez{% endtrans %}</a>.
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
